{
  "name": "hardware-system-backend",
  "version": "1.0.0",
  "description": "REST API for Liyanage Hardware Management System",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsup src/main.ts --outDir dist --format esm --clean --sourcemap",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "seed": "npx prisma db seed",
    "seed2": "ts-node --project prisma/tsconfig.seed.json --esm prisma/seed2.ts",
    "postinstall": "npx prisma generate",
    "studio": "npx prisma studio"
  },
  "prisma": {
    "seed": "ts-node --project prisma/tsconfig.seed.json --esm prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mariadb": "^3.5.3",
    "multer": "^2.1.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.4.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
